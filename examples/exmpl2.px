def main(Void): Void {
    def number: Byte = zero;
    
    io.print("Enter a number: ");
    io.scan("%", number);
    io.print(endl);
    
    if (number % 2 == 0) ->
        io.println("% even number", number);
    else ->
        io.println("% odd number", number);
    
exit:
    signal exit(0);
    return Void;
}
