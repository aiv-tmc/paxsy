#using "inout.hp"
#using "mathf.hp"
#using "type.hp"
#using "svc.hp"

pro calc(@Float): Noi80;

def main(Void): Void {
    io.println("%" calc({2.0, mth.PI(2):Float}));

exit:
    signal exit(0);
    return Void;
}

def calc(def nums[]: Float=none): Noi80 {
    def result: Noi80 = zero;

    def i: Byte = zero;
    do (i < (sizeof(nums)/sizeof(Float)) {
        result += nums[i];
        i++;
    }
    del @i;

    return result;
}
