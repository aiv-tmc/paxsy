#using "args"
#using "simac"
#using "inout"
#using "type"
#using "args"

#entry @start

start(Void) {
    io.print(
        calc( 1.9
            , 2
            , mth.PI(2)
        )
    );
    
    exit(0);
    return;
}

calc(num: Float, ...): Float {
    result: Float = zero;
    factor: VLS = zero;
    
    va.start(factor, num);
    
    {i: Byte=zero; do(i < num) {
        result += va.arg(factor, Real);
    i++;}}
    va.end(factor);
    
    return result;
}
