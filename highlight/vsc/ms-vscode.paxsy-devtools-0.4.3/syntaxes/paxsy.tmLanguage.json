{
    "name": "Paxsy",
    "scopeName": "source.paxsy",
    "fileTypes": ["paxsy", "pxs", "pax"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#preprocessor" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.paxsy",
                    "match": "//.*$",
                    "captures": {
                        "0": {
                            "patterns": [{ "include": "#todos" }]
                        }
                    }
                },
                {
                    "name": "comment.block.paxsy",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.comment.begin.paxsy" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.comment.end.paxsy" }
                    },
                    "patterns": [
                        { "include": "#todos" }
                    ]
                }
            ]
        },
        "todos": {
            "match": "\\b(TODO|FIXME|NOTE)\\b",
            "name": "comment.todo.paxsy"
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.paxsy",
                    "begin": "\"",
                    "end": "\"",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.string.begin.paxsy" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.string.end.paxsy" }
                    },
                    "patterns": [
                        {
                            "name": "constant.character.escape.paxsy",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.paxsy",
                    "begin": "'",
                    "end": "'",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.string.begin.paxsy" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.string.end.paxsy" }
                    },
                    "patterns": [
                        {
                            "name": "constant.character.escape.paxsy",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "preprocessor": {
            "name": "meta.preprocessor.paxsy",
            "begin": "#",
            "end": "$",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.preprocessor.paxsy" }
            },
            "patterns": [
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#operators" },
                { "include": "#types" },
                { "include": "#comments" },
                { "include": "#todos" }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.paxsy",
                    "match": "\\b\\d[\\da-zA-Z_.]*\\b"
                },
                {
                    "name": "constant.language.boolean.paxsy",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.null.paxsy",
                    "match": "\\b(none|zero)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.paxsy",
                    "match": "\\b(if|else|elif|do|break|continue|try|catch|jump|return|halt|interflag|signal|kill)\\b"
                },
                {
                    "name": "keyword.operator.word.paxsy",
                    "match": "\\b(or|and)\\b"
                },
                {
                    "name": "keyword.other.paxsy",
                    "match": "\\b(nop|sizeof|typeof|realloc|alloc|free|calloc|memset|memcpy|memcmp)\\b"
                },
                {
                    "name": "storage.type.state.paxsy",
                    "match": "\\b(def|del|pro)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.paxsy",
                    "match": "\\b(Int|Real|Char|Void|Auto|Struct|uInt|uReal|unsigned|signed|volatile|const|fixed|close|open|extern|static|regis|inline|Byte|Short|Rune|Word|Long|Float|Double|Noi80|Decimal|Size|Time|Bool|Str|VLS|Null)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "punctuation.paxsy",
                    "match": "[{}()\\[\\];,.]"
                },
                {
                    "name": "keyword.operator.paxsy",
                    "match": "[-+*/%@&$|^~=<>!?:]"
                }
            ]
        }
    }
}
